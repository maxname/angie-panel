#!/bin/sh
# postinst for angie-panel (used by cargo-deb).
#
# cargo-deb splices its unit and tmpfiles handling in at the debhelper token
# near the bottom. Never spell that token out anywhere else in this file,
# comments included: EVERY occurrence is substituted, so a mention in prose gets
# the generated block dropped into the middle of the sentence and leaves the
# tail of it running as a command. That is not hypothetical — this very line
# used to name the token, and installs ended up executing "token below — ..."
# and printing `postinst: 13: token: not found`. It only stayed harmless
# because the stray line landed above the `set -e` below.
#
# This script itself only manages the service account and the data directory.
set -e

case "$1" in
    configure)
        # Dedicated unprivileged service account. --group creates a matching
        # system group; home is the data dir but we create it ourselves below
        # to control ownership and mode exactly.
        if ! getent passwd angie-panel >/dev/null; then
            adduser --system --group \
                --home /var/lib/angie-panel --no-create-home \
                --shell /usr/sbin/nologin \
                --gecos "angie-panel service" \
                angie-panel
        fi

        # Data dir is private to the panel (DB, staging, backups, setup
        # token). install -d also fixes owner/mode on upgrades.
        install -d -o angie-panel -g angie-panel -m 0700 /var/lib/angie-panel
        # public/ holds the HTML default-site content served by Angie
        # workers, hence world-readable.
        install -d -o angie-panel -g angie-panel -m 0755 /var/lib/angie-panel/public

        # Edge cache directory for the "Cache assets" feature. Owned by the
        # Angie worker user so the root master can write cache entries; the
        # keys_zone is declared in the generated 00-panel.conf. Best-effort:
        # the owner exists only once Angie is installed.
        if getent passwd angie >/dev/null; then
            install -d -o angie -g angie -m 0750 /var/cache/angie-panel-assets
        else
            install -d -m 0750 /var/cache/angie-panel-assets
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0

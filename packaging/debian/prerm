#!/bin/sh
# prerm for angie-panel (used by cargo-deb).
# Stopping the units on remove/upgrade is handled by the snippets cargo-deb
# inserts at the debhelper token near the bottom. Do not spell that token out
# here, not even in a comment — see postinst for what that costs.
# Nothing package-specific to do here.
set -e

case "$1" in
    remove|upgrade|deconfigure)
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
